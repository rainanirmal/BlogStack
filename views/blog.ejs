<!DOCTYPE html>
<html lang="en">

<head>
  <%- include("./partials/head") %>
    <title>
      <%= blog.title %>
    </title>
</head>

<body class="bg-light">

  <%- include("./partials/nav") %>

    <div class="container py-5">

      <div class="card shadow-lg border-0">

        <!-- Cover Image -->
        <img src="<%= blog.coverImageURL %>" class="card-img-top" alt="Cover Image"
          style="max-height:500px; object-fit:cover;">

        <div class="card-body p-5">

          <!-- Title -->
          <h1 class="fw-bold mb-3">
            <%= blog.title %>
          </h1>

          <!-- Author & Date -->
          <div class="d-flex justify-content-between align-items-center mb-4">

            <div>
              <img src="<%= blog.createdBy.profileImaggeURL %>" alt="" width="40px">
              <strong>
                <%= blog.createdBy.fullName %>
              </strong>
            </div>

            <div class="text-muted">
              <%= new Date(blog.createdAt).toLocaleDateString( "en-IN" , { day: "numeric" , month: "long" ,
                year: "numeric" , } ) %>
            </div>

          </div>

          <hr>

          <div class="mt-4 fs-5 lh-lg" style="white-space: pre-line;">
            <%= blog.body %>
          </div>

          <hr class="my-5">

          <!-- Comment Form -->

          <h3 class="mb-4">
            Leave a Comment
          </h3>

          <% if(user){ %>

            <form action="/blog/comment/<%= blog._id %>" method="POST">

              <div class="mb-3">

                <textarea class="form-control" rows="4" name="content" placeholder="Write your comment..."
                  required></textarea>

              </div>

              <button class="btn btn-primary" type="submit">
                Post Comment
              </button>

            </form>

            <% } else { %>

              <div class="alert alert-info">

                Please
                <a href="/user/signin">
                  Sign In
                </a>
                to comment on this blog.

              </div>

              <% } %>

                <hr class="my-5">

                <!-- Comments -->

                <h3 class="mb-4">

                  Comments

                  <% if(locals.comments){ %>

                    (<%= comments.length %>)

                      <% } %>

                </h3>

                <% if(locals.comments && comments.length> 0){ %>

                  <% comments.forEach(comment=> { %>

                    <div class="card mb-3 shadow-sm">

                      <div class="card-body">

                        <div class="d-flex justify-content-between">

                          <h6 class="fw-bold">

                            <%= comment.createdBy.fullName %>

                          </h6>

                          <small class="text-muted">

                            <%= new Date(comment.createdAt) .toLocaleDateString("en-IN") %>

                          </small>

                        </div>

                        <p class="mt-3 mb-0">

                          <%= comment.content %>

                        </p>

                      </div>

                    </div>

                    <% }) %>

                      <% } else { %>

                        <div class="alert alert-secondary">

                          No comments yet.

                          Be the first one to comment!

                        </div>

                        <% } %>

        </div>

        <div class="card-footer bg-white">

          <a href="/" class="btn btn-outline-primary">
            ← Back to Home
          </a>

        </div>

      </div>

    </div>

    <%- include("./partials/script") %>

</body>

</html>