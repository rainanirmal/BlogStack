<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("./partials/head") %>
    <title>BlogStack</title>
  </head>

  <body>

    <%- include("./partials/nav") %>

    <% if (!user) { %>

      <!-- Guest View -->

      <div class="container mt-5">

        <div class="text-center py-5">

          <h1 class="display-4 fw-bold">
            Welcome to BlogStack
          </h1>

          <p class="lead text-muted mt-3">
            Discover amazing blogs written by our community.
            Create an account or sign in to start reading and publishing blogs.
          </p>

          <div class="mt-4">

            <a href="/user/signin" class="btn btn-primary btn-lg me-2">
              Sign In
            </a>

            <a href="/user/signup" class="btn btn-outline-primary btn-lg">
              Create Account
            </a>

          </div>

        </div>

      </div>

    <% } else { %>

      <!-- Logged-in User View -->

      <div class="container mt-5">

        <div class="row g-4">

          <% blog.forEach(blog => { %>

            <div class="col-md-6 col-lg-4">

              <div class="card h-100 shadow-sm">

                <img
                  src="<%= blog.coverImageURL %>"
                  class="card-img-top"
                  alt="Cover Image"
                  style="height:220px; object-fit:cover;"
                >

                <div class="card-body d-flex flex-column">

                  <h4 class="card-title">
                    <%= blog.title %>
                  </h4>

                  <p class="mb-2">
                    By
                    <strong>
                      <%= blog.createdBy.fullName %>
                    </strong>
                  </p>

                  <p class="text-muted">
                    <%= blog.body.substring(0,100) %>...
                  </p>

                  <div class="mt-auto">

                    <a
                      href="/blog/<%= blog._id %>"
                      class="btn btn-primary w-100"
                    >
                      Read More
                    </a>

                  </div>

                </div>

              </div>

            </div>

          <% }) %>

        </div>

      </div>

    <% } %>

    <%- include("./partials/script") %>

  </body>
</html>